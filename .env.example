# API-ключи
OPENROUTER_API_KEY=sk-or-v1-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...
CHATBOT_TG_TOKEN=...

# Bootstrap-дефолты (используются ТОЛЬКО если в settings Supabase ещё нет записей;
# после первого запуска источник правды — таблица settings в Supabase)
DEFAULT_CHATBOT_PROVIDER=openrouter
DEFAULT_CHATBOT_MODEL=anthropic/claude-haiku-4-5

# Supabase (та же что у основного магазина)
SUPABASE_URL=https://...supabase.co
SUPABASE_ANON_KEY=...
# service_role-ключ: нужен серверу, логгеру и TG-боту (запись в settings/логи/watchlist)
SUPABASE_SERVICE_KEY=...

# Сервис
PORT=3002
RATE_LIMIT_PER_DAY=20
RATE_LIMIT_PER_MINUTE=5
MAX_MESSAGE_LENGTH=500
MAX_HISTORY_MESSAGES=10
OFFTOP_BLOCK_THRESHOLD=3

# Контакты менеджера (готовность к будущему in-site chat)
MANAGER_PRIMARY_TYPE=telegram
MANAGER_PRIMARY_VALUE=@your_telegram
MANAGER_FALLBACK_TYPE=vk
MANAGER_FALLBACK_VALUE=https://vk.com/your_group

# Логирование (true на старте; переключить на false после 2 мес → семплирование)
LOG_ALL_CONVERSATIONS=true
